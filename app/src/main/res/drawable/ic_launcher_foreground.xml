<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Snowflake main arms (cooling) -->
    <path
        android:pathData="M54,22 L54,86 M26.3,38 L81.7,70 M81.7,38 L26.3,70"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:startColor="#7CF5FF"
                android:endColor="#00B8CC" />
        </aapt:attr>
    </path>

    <!-- Snowflake tip branches -->
    <path
        android:pathData="M54,22 L47,29 M54,22 L61,29
                           M54,86 L47,79 M54,86 L61,79
                           M81.7,38 L74,33 M81.7,38 L76,46
                           M26.3,70 L34,75 M26.3,70 L32,62
                           M26.3,38 L34,33 M26.3,38 L32,46
                           M81.7,70 L74,75 M81.7,70 L76,62"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="20"
                android:startY="20"
                android:endX="90"
                android:endY="90"
                android:startColor="#7CF5FF"
                android:endColor="#00B8CC" />
        </aapt:attr>
    </path>

    <!-- Center glow disc behind the bolt for contrast -->
    <path
        android:pathData="M54,40 C63,40 70,47 70,56 C70,65 63,72 54,72 C45,72 38,65 38,56 C38,47 45,40 54,40 Z"
        android:fillColor="#1A0A0E1A" />

    <!-- Lightning bolt (boost/performance) -->
    <path
        android:pathData="M59,41 L48,58 L54,58 L50,71 L64,53 L56,53 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="48"
                android:startY="41"
                android:endX="64"
                android:endY="71"
                android:startColor="#FFB280"
                android:endColor="#FF7A45" />
        </aapt:attr>
    </path>
